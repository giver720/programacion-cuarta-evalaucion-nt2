#include <iostream>
#include <windows.h>
#include <conio.h>

void gotoxy(int x,int y){  
      HANDLE hcon;  
      hcon = GetStdHandle(STD_OUTPUT_HANDLE);  
      COORD dwPos;  
      dwPos.X = x;  
      dwPos.Y= y;  
      SetConsoleCursorPosition(hcon,dwPos);  
 }  

int main() {
    int op;
    do {
        system("cls");
        gotoxy(20,5); std::cout << "MENU DE FIGURAS";
        gotoxy(20,7); std::cout << "1. Cuadrado";
        gotoxy(20,8); std::cout << "2. Triangulo";
        gotoxy(20,9); std::cout << "3. Rectangulo";
        gotoxy(20,10); std::cout << "4. Salir";
        gotoxy(20,12); std::cout << "Opcion: ";
        std::cin >> op;
        system("cls");

        if(op == 1) {
            int x=15, y=6, lado=8;
            for(int i=0; i<lado; i++) {
                gotoxy(x+i, y); std::cout << "-";
                gotoxy(x+i, y+lado-1); std::cout << "-";
            }
            for(int i=1; i<lado-1; i++) {
                gotoxy(x, y+i); std::cout << "|";
                gotoxy(x+lado-1, y+i); std::cout << "|";
            }
            gotoxy(x,y); std::cout << "+";
            gotoxy(x+lado-1,y); std::cout << "+";
            gotoxy(x,y+lado-1); std::cout << "+";
            gotoxy(x+lado-1,y+lado-1); std::cout << "+";
            gotoxy(15, y+lado+2); std::cout << "Cuadrado - Presiona tecla para continuar...";
            _getch();
        } 
        else if(op == 2) {
            int base_x = 20;
            int base_y = 10;
            for(int i=0; i<6; i++) {
                gotoxy(base_x - i, base_y + i);
                for(int j=0; j < (2*i +1); j++) {
                    std::cout << "*";
                }
            }
            gotoxy(15, base_y + 8); std::cout << "Triangulo - Presiona tecla para continuar...";
            _getch();
        } 
        else if(op == 3) {
            int x=10, y=5, ancho=25, alto=8;
            for(int i=0; i<ancho; i++) {
                gotoxy(x+i, y); std::cout << "-";
                gotoxy(x+i, y+alto-1); std::cout << "-";
            }
            for(int i=1; i<alto-1; i++) {
                gotoxy(x, y+i); std::cout << "|";
                gotoxy(x+ancho-1, y+i); std::cout << "|";
            }
            gotoxy(x,y); std::cout << "+";
            gotoxy(x+ancho-1,y); std::cout << "+";
            gotoxy(x,y+alto-1); std::cout << "+";
            gotoxy(x+ancho-1,y+alto-1); std::cout << "+";
            gotoxy(10, y+alto+2); std::cout << "Rectangulo - Presiona tecla para continuar...";
            _getch();
        }
    } while(op != 4);
    return 0;
}
