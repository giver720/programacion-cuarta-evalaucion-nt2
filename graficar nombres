#include <iostream>
#include <windows.h>
#include <conio.h>
#include <string>
#include <cctype>

void gotoxy(int x,int y){  
      HANDLE hcon;  
      hcon = GetStdHandle(STD_OUTPUT_HANDLE);  
      COORD dwPos;  
      dwPos.X = x;  
      dwPos.Y= y;  
      SetConsoleCursorPosition(hcon,dwPos);  
 }  

std::string letterPatterns[26][5] = {
    {"  *  ", " * * ", "*****", "*   *", "*   *"}, // A
    {"**** ", "*   *", "**** ", "*   *", "**** "}, // B
    {" ****", "*    ", "*    ", "*    ", " ****"}, // C
    {"**** ", "*   *", "*   *", "*   *", "**** "}, // D
    {"*****", "*    ", "*****", "*    ", "*****"}, // E
    {"*****", "*    ", "*****", "*    ", "*    "}, // F
    {" ****", "*    ", "*  **", "*   *", " ****"}, // G
    {"*   *", "*   *", "*****", "*   *", "*   *"}, // H
    {"*****", "  *  ", "  *  ", "  *  ", "*****"}, // I
    {"  ***", "   * ", "   * ", "*  * ", " **  "}, // J
    {"*   *", "*  * ", "***  ", "*  * ", "*   *"}, // K
    {"*    ", "*    ", "*    ", "*    ", "*****"}, // L
